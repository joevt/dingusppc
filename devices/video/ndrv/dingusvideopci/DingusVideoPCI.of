\ ========================================================================================
\ PCI header

tokenizer[ D15C 0001 038000 ]tokenizer pci-header

\ eval might use fcode numbers starting from 0x800 so we'll start at 0x820.
tokenizer[ 820 next-fcode ]tokenizer

fcode-version2

hex

." [ DingusVideoParent" cr

	external
	\ headerless

	\ ====================================================================================
	\ Debugging utilities
	
	: .stack ." stack: " .s ;
	.stack
	
	0 value save-depth
	: save-stack[ depth to save-depth ;
	: ]restore-stack depth save-depth ?do drop loop ;
	: .saved-stack depth save-depth - begin dup while dup pick . 1- repeat drop cr ;
	
	\ ====================================================================================
	\ Open Firmware fixes
	
	." fix $find" cr
	.stack
	
	\ $find in Open Firmware 1.0.5 incorrectly returns 4 items on the stack instead of 3 for not found result
	: ($my-find) ( str len -- xt true | str len false )
		$find		\ xt true | str len false
		dup 0= if	\ pstr str len false
			3 roll	\ str len false pstr
			drop	\ str len false
		then
		;
	
	defer $my-find
	save-stack[
		" " $find
		depth save-depth - 4 = if ." $find has problem" cr ['] ($my-find) else ['] $find ." $find is ok" cr then to $my-find
	]restore-stack
	
	.stack
	
	\ ====================================================================================
	\ Debug logging
	
	save-stack[ my-address ." my-address: " .saved-stack ]restore-stack \ ( -- phys.lo ... )			0 0
	save-stack[ my-space   ." my-space: "   .saved-stack ]restore-stack \ ( -- phys.hi )				6800		(for PCI slot @D)
	save-stack[ my-unit    ." my-unit: "    .saved-stack ]restore-stack \ ( -- phys.lo ... phys.hi )	0 0 0
	save-stack[ my-args    ." my-args: "    .saved-stack ]restore-stack \ ( -- arg-str arg-len )		0 0
	
	\ ====================================================================================
	\ Structs

	struct
		4 field >M.num-displays
	constant meta-regs-size
	
	struct
		4 field >D.hactive
		4 field >D.hsyncbegin
		4 field >D.hsyncend
		4 field >D.htotal
		4 field >D.vactive
		4 field >D.vsyncbegin
		4 field >D.vsyncend
		4 field >D.vtotal
		4 field >D.mon-sense
		4 field >D.timing-flags
		4 field >D.immediate-flags
		4 field >D.pixel-clock
		4 field >D.pixel-depth
		4 field >D.framebuffer-base
		4 field >D.framebuffer-rowbytes
		4 field >D.int-enable
		4 field >D.int-status
		4 field >D.hwcursor-base
		4 field >D.hwcursor-width
		4 field >D.hwcursor-pos
		4 field >D.color-index
		4 field >D.color-data
	constant display-regs-size

	struct
		4 field >I.display-regs
		4 field >I.fb-address-phys
		4 field >I.fb-address
		2 field >I.width
		2 field >I.height
		1 field >I.opened
	constant display-info-size

	struct
		4 field >T.pixel-clock

		2 field >T.display-mode-number
		2 field >T.width
		2 field >T.height

		2 field >T.hactive
		2 field >T.hsyncbegin
		2 field >T.hsyncend
		2 field >T.htotal

		2 field >T.vactive
		2 field >T.vsyncbegin
		2 field >T.vsyncend
		2 field >T.vtotal

		1 field >T.hpolarity
		1 field >T.vpolarity
		1 field >T.interlaced
		1 field >T.csyncdisabled

		d# 10 field >T.note
	constant display-timing-size \ 40 bytes

	struct
		4 field >V.display-timing
		4 field >V.vic
	constant vic-entry-size

	\ ====================================================================================
	\ Dictionary

	\ this differs from the one in ROM since it will check for zero length
	: $c, bounds ?do i c@ c, loop ;

	\ ====================================================================================
	\ Data

	false constant N
	true  constant P
	: mode, d# 18 0 do i roll loop                 l,   w,    w,    w,    w,    w,    w,    w,     w,    w,    w,    w, c, c, c,     c,     over $c, d# 10 swap ?do 0 c, loop ;
