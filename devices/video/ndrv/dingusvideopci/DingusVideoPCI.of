	\ ====================================================================================
	\ Words

	: map-in    " map-in"    $call-parent ; ( phys.low phys.mid phys.hi size -- virt )
	: map-out   " map-out"   $call-parent ; ( virt size -- )
	: config-l@ " config-l@" $call-parent ; ( config-addr -- data )
	: config-l! " config-l!" $call-parent ; ( data config-addr -- )

	: my-config-l@ ( reg -- x )
		my-space + config-l@ ;

	: my-config-l! ( x reg -- )
		my-space + config-l! ;

	\ Get the BAR value, check the size, and restore the BAR
	: get-bar-size ( bar -- size )
		my-space + dup config-l@ swap -1 over config-l! dup config-l@ -10 and negate -rot config-l! ;								

	\ ====================================================================================
	\ DingusVideo parent
	
	10 get-bar-size constant vram-size
	30 get-bar-size constant rombar-size
	
	." map-in memory space" cr
	\ relocatable, prefetchable, 32-bit memory space
	\ I/O shouldn't be prefetchable but we're an emulated device so we don't care
	my-address h# 42000010 my-space + vram-size map-in value vram-base
	vram-base l@ dup constant num-displays
	vram-base vram-size map-out
	-1 to vram-base

	display-regs-size * meta-regs-size + h# FFF + h# -1000 and dup constant all-regs-size
	vram-size swap - h# -1000 and constant vram-per-display

	." rombar-size: " rombar-size . cr
	." vram-size: " vram-size . cr
	." num-displays: " num-displays . cr
	." meta-regs-size" meta-regs-size . cr
	." display-regs-size" display-regs-size . cr
	." all-regs-size" all-regs-size . cr
	." vram-per-display" vram-per-display . cr

	." setting reg" cr
	.stack
	
	my-address my-space               encode-phys         0 encode-int encode+ 0           encode-int encode+ \ config space
	my-address my-space h# 42000010 + encode-phys encode+ 0 encode-int encode+ vram-size   encode-int encode+ \ relocatable, prefetchable, 32-bit memory space
	my-address my-space h# 02000030 + encode-phys encode+ 0 encode-int encode+ rombar-size encode-int encode+ \ relocatable, 32-bit memory space
	" reg" property
	
	30 my-config-l@ value rombar
	." rombar: " rombar . cr
	
	." map-in rom" cr
	my-address h# 02000030 my-space + rombar-size map-in value rom-base
	30 my-config-l@ dup ." new rombar: " . cr 1 or 30 my-config-l!
	." [ rom-mapped" cr
	.stack
	
	." rom-base: " rom-base . cr
	\ rom-base rombar-size " dump" eval cr
	.stack
	
	\ This should be used like this: " findme" byte-load-from-rom 0 if ... then
	\ It will execute the fcode represented by ...
	\ str should be unique in the entire rom.
	: byte-load-from-rom ( str len -- ? )
		." [ byte-load-from-rom" cr
			.stack
			." rombar-size: " rombar-size . cr
			." rom-base: " rom-base . cr

			rombar-size						\ str len rombar-size
			over							\ str len rombar-size str
			-								\ str len rombar-size-str
			rom-base						\ str len rombar-size-str rom-base
			swap							\ str len rom-base rombar-size-str
			bounds							\ str len rom-base+rombar-size-str rom-base
			?do								\ str len
				2dup i						\ str len str len i 
				swap						\ str len str i len
				comp						\ str len (0=equal|not 0=not equal)
				0=							\ str len equal?
				over i +					\ str len equal? len+i
				c@ f1 =						\ str len equal? *(len+i)==f1
				and							\ str len (equal and followed by f1)
				if							\ str len
					." foundit" cr
					nip						\ len
					i +						\ i+len \ skip bytes for str (len)
					1 byte-load				\ ( addr xt -- )
					\ can't use exit - it will mess up the loop stack, so put 2 items on the stack and use leave
					0 0						\ 0 0
					leave					\ 0 0
				then						\ str len
			loop							\ str len
			2drop							\
		." ] byte-load-from-rom" cr
		;

	defer my-parse-1hex
	false value has-unit-address

	." looking for parse-1hex" cr
	.stack

	" parse-1hex" $my-find if
		." setting decode-unit" cr
		to my-parse-1hex
		1 encode-int " #address-cells" property
		0 encode-int " #size-cells" property
		" : decode-unit parse-1hex ;" evaluate
		true to has-unit-address
	else
		2drop
	then
	.stack

	." before eval" cr
	" : decode-unit parse-1hex ;" evaluate
	." after eval" cr
	.stack

\ ========================================================================================
\ Display words

	create std-16
	\		black    blue  green  cyan   red   magenta brown white
		" "(000000 0000AA 00AA00 00AAAA AA0000 AA00AA AA5500 AAAAAA)" $c,
	\		grey    blue  green  cyan   red   magenta yellow white			- bright
		" "(555555 5555FF 55FF55 55FFFF FF5555 FF55FF FFFF55 FFFFFF)" $c,

	create std-gamma
		" "(00 05 09 0B 0E 10 13 15 17 19 1B 1D 1E 20 22 24)" $c,
		" "(25 27 28 2A 2C 2D 2F 30 31 33 34 36 37 38 3A 3B)" $c, 
		" "(3C 3E 3F 40 42 43 44 45 47 48 49 4A 4B 4D 4E 4F)" $c, 
		" "(50 51 52 54 55 56 57 58 59 5A 5B 5C 5E 5F 60 61)" $c, 
		" "(62 63 64 65 66 67 68 69 6A 6B 6C 6D 6E 6F 70 71)" $c, 
		" "(72 73 74 75 76 77 78 79 7A 7B 7C 7D 7E 7F 80 81)" $c, 
		" "(81 82 83 84 85 86 87 88 89 8A 8B 8C 8C 8D 8E 8F)" $c, 
		" "(90 91 92 93 94 95 95 96 97 98 99 9A 9B 9B 9C 9D)" $c, 
	
		" "(9E 9F A0 A1 A1 A2 A3 A4 A5 A6 A6 A7 A8 A9 AA AB)" $c, 
		" "(AB AC AD AE AF B0 B0 B1 B2 B3 B4 B4 B5 B6 B7 B8)" $c, 
		" "(B8 B9 BA BB BC BC BD BE BF C0 C0 C1 C2 C3 C3 C4)" $c, 
		" "(C5 C6 C7 C7 C8 C9 CA CA CB CC CD CD CE CF D0 D0)" $c, 
		" "(D1 D2 D3 D3 D4 D5 D6 D6 D7 D8 D9 D9 DA DB DC DC)" $c, 
		" "(DD DE DF DF E0 E1 E1 E2 E3 E4 E4 E5 E6 E7 E7 E8)" $c, 
		" "(E9 E9 EA EB EC EC ED EE EE EF F0 F1 F1 F2 F3 F3)" $c, 
		" "(F4 F5 F5 F6 F7 F8 F8 F9 FA FA FB FC FC FD FE FF)" $c,
	
	: c+		( adr -- adr+1 val ) 
		dup 1+ swap c@
		;

	: c!+		( adr val -- adr+1 ) 
		swap dup 1+ -rot c!
		;

	: do-gamma
		std-gamma + c@
		;

	: anti-gamma	( val -- orig )
		h# 100 0 do 
			std-gamma i + c@ over >= if
				drop i unloop exit
			then
		loop
		drop h# ff
		;
	

	: ping-dingus-display	( enable-bit -- )
		dup 8 or ( enable-bit enable-bit|8 -- )
		swap dup regs >C.TEST rl! 5 ms ( enable-bit|8 enable-bit   -- ) \ 1
		swap dup regs >C.TEST rl! 5 ms ( enable-bit   enable-bit|8 -- ) \ 2
		swap dup regs >C.TEST rl! 5 ms ( enable-bit|8 enable-bit   -- ) \ 3
		swap dup regs >C.TEST rl! 5 ms ( enable-bit   enable-bit|8 -- ) \ 4
		2drop
		;

	: reset-dingus-display
		h# 433 ping-dingus-display \ disable display
		;

	: enable-dingus-display
		h# 033 ping-dingus-display
		;

	: init-dingus-display	( tbl-ptr -- )

		d# 16 0 do			\ loop over most dingus-display regs
			w@++ ( dup .d ) regs >C.VFPEQ i 4 << + ( dup .h cr ) rl!
			loop

		w@++	regs >C.GSC-DIVIDE rl!
		w@++ dup to width	regs >C.ROW-WORDS rl!
		w@ to height
			little? 2 and or	regs >C.ENABLE rl!
		0		regs >C.GBASE rl!
		h# 01e4	regs >C.REFRESH-COUNT rl!
		0		regs >C.INT-ENABLE rl!
		;
	
	: p-dimensions ( display-info -- width height )
		dup  >I.width  w@ \ display-info *(display-info.>I.width)
		swap >I.height w@ \ *(display-info+>I.width) *(display-info.>I.height)
		;

	: p-set-colors ( adr index #indices display-info )
	
		swap rad-reg-addr!					\ initialize index
		( #indices ) 0 ?do				( adr )
	
			mono-mode? if
	
				c+ h# 4d * >r				( red adr )
				c+ h# 97 * >r				( red green adr )
				c+ h# 1c * 					( red green blue adr )
				r> + r> + 8 >>				( luminance )
				do-gamma
				dup 		\ r
				dup			\ g
				clut!		\ b
											( adr )
			else
				c+ do-gamma swap			( r adr )
				c+ do-gamma swap			( r g adr )
				c+ do-gamma swap  			( r g b adr )
				>r swap rot clut! r>		( b g r )
			then
		loop						( adr )
		drop
		;

	: p-get-colors ( adr index #indices display-info -- )
		swap ( index ) rad-reg-addr! ( #indices )  0 ?do
			clut@ anti-gamma >r anti-gamma >r anti-gamma		( r )
			c!+ r> c!+ r> c!+
			loop
		drop
		;

	: p-color! ( r g b index display-info -- )
		>r rgb-temp 2+ c! rgb-temp 1+ c! rgb-temp c!	\ setup our packed buffer
		rgb-temp r> 1 set-colors						\  and, use our own code
		;

	: p-color@ ( index display-info -- r g b )
		rgb-temp swap 1 get-colors					\ fetch one set
		rgb-temp c+ swap c+ swap c@					\ split them out
		;
	
	: p-rect-setup ( adr|index x y w h display-info -- w adr|index xy-adr h )
		>r >r width * + fb-address + r> -rot r>
		;
	
	: p-draw-rectangle ( adr x y w h display-info -- )
		rect-setup 		\ drop						( w adr xy-adr h )
		( h ) 0 ?do								( w adr xy-adr )
			2dup 4 pick move
			2 pick width d+
			loop
		3drop
		;

	: p-fill-rectangle ( index x y w h display-info -- )
		rect-setup 								( w index xy-adr h )
		( h ) 0 ?do								( w index xy-adr )
			dup 3 pick 3 pick fill
			width +
			loop
		3drop
		;

	: p-read-rectangle ( adr x y w h display-info -- )
		rect-setup  >r swap r>					( w xy-adr adr h )
		( h ) 0 ?do
			2dup 4 pick move
			width 3 pick d+
			loop
		3drop
		;

	-1 value vram-base-phys
	0 value open-count

	: p-my-open ( display-info -- )
		open-count 0= if
			" assigned-addresses" get-my-property
				abort" no REG property"	( prop-adr prop-len )
			begin
				dup 0> while
				decode-int h# FF and >r decode-int drop decode-int >r
				8 - swap 8 + swap ( prop-adr prop-len )
				r> r> case
					h# 10 of
						to vram-base-phys
						endof
					swap drop
					endcase
				repeat
			2drop
	
			vram-base-phys 0 my-space h# 42000000 or all-regs-size map-in to vram-base
			open-count 1+ to open-count
		then

		reset-dingus-display					\ force reset of timing, etc.
		mon-sense
		get-mode swap to mono-mode?		\ ptr to one of the mode tables is now on the stack
		( mode-dependent-table-addr )

		dup 0= if 
			abort
		then

		( mode-dependent-table-addr ) 
		init-dingus-display					\ with monitor sensing
		std-16 0 d# 16 set-colors
		enable-dingus-display
	
		fb-address-phys 0 my-space h# 02000000 or width height * map-in to fb-address
	
		\ clear screen mem to gray. (Need VRAM state machine on!)
		fb-address width height * 7 fill
	
		default-font set-font
		width height over 20 - char-width / over 20 - char-height / fb8-install
		width #columns char-width * - 2/ to window-left
		height #lines char-height * - 2/ to window-top
		fb-address to frame-buffer-adr

		width encode-int " width" property
		height encode-int " height" property
		width encode-int " linebytes" property
		8 encode-int " depth" property
		;
	
	
	: p-my-close ( display-info -- )
		fb-address height width * map-out
		
		open-count if
			vram-base all-regs-size map-out
			open-count 1- to open-count
		then
		;

\ ========================================================================================
\ DingusVideo children

	: create-displays
		\ this has to be done from compiled code because OF 1.0.5
		num-displays 0 ?do
			i new-device " runme" byte-load-from-rom finish-device
		loop
		;
	create-displays

\ ========================================================================================
\ Parent Epilogue
	
	30 my-config-l@ dup ." rombar: " . cr -2 and 30 my-config-l!
	rom-base rombar-size map-out
	rombar 30 my-config-l!

	0 to rom-base
	." ] rom-mapped" cr
	
	" DingusVideoParent" device-name
	
	.stack
." ] DingusVideoParent" cr

fcode-end
\ ========================================================================================
" runme"
fcode-version2 ( display-number -- )

	dup constant display-number

	create display-info
		dup display-regs-size * meta-regs-size + vram-base + l, \ display-regs
		vram-per-display * all-regs-size + vram-base + l, \ fb-address-phys
		0 l,        \ fb-address
		0 w,		\ width
		0 w,		\ height
		0 c,        \ opened
		display-number c,

	.stack

	." [ DingusVideo #" display-number . cr
	.stack
	." making new device" cr

	" DingusVideo_A" encode-string 2dup + 2- 41 display-number + swap c! " name" property
	" DingusVideo" encode-string " compatible" property

	has-unit-address if
		." making new device reg" cr
		display-number encode-int " reg" property
	then

	external

	: dimensions     ( -- width height )       display-info p-dimensions     ;
	: set-colors     ( adr index #indices )    display-info p-set-colors     ;
	: get-colors     ( adr index #indices -- ) display-info p-get-colors     ;
	: color!         ( r g b index -- )        display-info p-color!         ;
	: color@         ( index -- r g b )        display-info p-color@         ;
	: draw-rectangle ( adr x y w h -- )        display-info p-draw-rectangle ;
	: fill-rectangle ( index x y w h -- )      display-info p-fill-rectangle ;
	: read-rectangle ( adr x y w h -- )        display-info p-read-rectangle ;

	\ headerless

	: my-open        ( -- )                    display-info p-my-open        ;
	: my-close       ( -- )	                   display-info p-my-close       ;

	['] my-open  is-install
	['] my-close is-remove

	." ] DingusVideo #" display-number . cr
	.stack
fcode-end
\ ========================================================================================
pci-end
